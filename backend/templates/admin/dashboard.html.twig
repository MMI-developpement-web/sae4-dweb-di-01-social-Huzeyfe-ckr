<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Dashboard</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', sans-serif;
            background: #000;
            color: #fff;
            min-height: 100vh;
        }

        .header {
            background: #000;
            border-bottom: 1px solid #38444d;
            padding: 16px 24px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            position: sticky;
            top: 0;
            z-index: 100;
        }

        .header-left {
            display: flex;
            align-items: center;
            gap: 16px;
        }

        .logo {
            font-size: 32px;
            font-weight: 900;
            letter-spacing: -1px;
        }

        .admin-info {
            display: flex;
            flex-direction: column;
        }

        .admin-name {
            font-size: 15px;
            font-weight: 700;
        }

        .admin-label {
            font-size: 13px;
            color: #b0b9c1;
        }

        .header-right {
            display: flex;
            gap: 12px;
        }

        .logout-btn {
            background: #1da1f2;
            color: #fff;
            border: none;
            padding: 8px 16px;
            border-radius: 20px;
            font-size: 14px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.2s;
        }

        .logout-btn:hover {
            background: #1a91da;
        }

        .container {
            max-width: 1200px;
            margin: 0 auto;
            padding: 32px 24px;
        }

        .welcome {
            margin-bottom: 32px;
        }

        .welcome h1 {
            font-size: 32px;
            font-weight: 900;
            margin-bottom: 8px;
        }

        .welcome p {
            font-size: 15px;
            color: #b0b9c1;
            line-height: 1.5;
        }

        .cards-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
            gap: 16px;
            margin-bottom: 32px;
        }

        .card {
            background: #16191c;
            border: 1px solid #38444d;
            border-radius: 16px;
            padding: 24px;
            text-decoration: none;
            color: #fff;
            transition: all 0.2s;
            cursor: pointer;
            display: flex;
            flex-direction: column;
        }

        .card:hover {
            background: #22272d;
            border-color: #1da1f2;
        }

        .card-icon {
            font-size: 28px;
            margin-bottom: 16px;
        }

        .card-title {
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 8px;
        }

        .card-description {
            font-size: 13px;
            color: #b0b9c1;
            line-height: 1.5;
        }

        .stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 16px;
            margin-bottom: 32px;
        }

        .stat-box {
            background: #16191c;
            border: 1px solid #38444d;
            border-radius: 16px;
            padding: 20px;
            text-align: center;
        }

        .stat-number {
            font-size: 28px;
            font-weight: 900;
            color: #1da1f2;
            margin-bottom: 8px;
        }

        .stat-label {
            font-size: 13px;
            color: #b0b9c1;
        }

        .footer {
            text-align: center;
            font-size: 12px;
            color: #657786;
            border-top: 1px solid #38444d;
            padding: 24px;
            margin-top: 40px;
        }

        @media (max-width: 768px) {
            .container {
                padding: 16px 12px;
            }

            .welcome h1 {
                font-size: 24px;
            }

            .cards-grid {
                grid-template-columns: 1fr;
            }
        }
    </style>
</head>
<body>
    <div class="header">
        <div class="header-left">
            <div class="logo">𝕏</div>
            <div class="admin-info">
                <div class="admin-name">{{ admin.name }}</div>
                <div class="admin-label">🔒 Administrateur</div>
            </div>
        </div>
        <div class="header-right">
            <a href="/admin/logout" class="logout-btn">Déconnexion</a>
        </div>
    </div>

    <div class="container">
        <div class="welcome">
            <h1>Bienvenue dans l'administration</h1>
            <p>Gérez l'ensemble de votre plateforme depuis ce tableau de bord.</p>
        </div>

        <div class="stats">
            <div class="stat-box">
                <div class="stat-number" id="post-count">-</div>
                <div class="stat-label">Posts</div>
            </div>
            <div class="stat-box">
                <div class="stat-number" id="user-count">-</div>
                <div class="stat-label">Utilisateurs</div>
            </div>
        </div>

        <div class="cards-grid">
            <a href="/admin/post" class="card">
                <div class="card-icon">📝</div>
                <div class="card-title">Gestion des Posts</div>
                <div class="card-description">Voir, éditer et supprimer les posts publiés par les utilisateurs</div>
            </a>

            <a href="/admin/user" class="card">
                <div class="card-icon">👥</div>
                <div class="card-title">Gestion des Utilisateurs</div>
                <div class="card-description">Gérer les comptes, rôles et permissions des utilisateurs</div>
            </a>

            <a href="/" class="card">
                <div class="card-icon">🏠</div>
                <div class="card-title">Retour au Site</div>
                <div class="card-description">Revenir à l'interface utilisateur publique</div>
            </a>
        </div>
    </div>

    <div class="footer">
        <p>© 2026 X Corp. - Administration Sécurisée</p>
    </div>

    <script>
        // Optional: Fetch stats from API
        async function loadStats() {
            try {
                // Remplace par tes endpoints API réels
                // const posts = await fetch('/api/posts').then(r => r.json());
                // const users = await fetch('/api/users').then(r => r.json());
                // document.getElementById('post-count').textContent = posts.length;
                // document.getElementById('user-count').textContent = users.length;
            } catch (error) {
                console.log('Stats not available');
            }
        }
        
        // loadStats();
    </script>
</body>
</html>
