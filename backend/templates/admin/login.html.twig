<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin - Connexion</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'Roboto', 'Oxygen', sans-serif;
            background: #000;
            color: #fff;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            align-items: center;
            padding: 32px 24px;
        }

        .logo {
            font-size: 48px;
            font-weight: 900;
            margin-bottom: 40px;
            letter-spacing: -2px;
        }

        .container {
            width: 100%;
            max-width: 400px;
        }

        h1 {
            font-size: 48px;
            font-weight: 900;
            margin-bottom: 8px;
            line-height: 1.2;
        }

        .subtitle {
            font-size: 24px;
            font-weight: 900;
            margin-bottom: 32px;
            color: #e1e8ed;
        }

        .error-message {
            background-color: rgba(220, 38, 38, 0.1);
            border: 1px solid rgba(220, 38, 38, 0.3);
            color: #ff6b6b;
            padding: 12px 15px;
            border-radius: 8px;
            margin-bottom: 24px;
            font-size: 14px;
        }

        form {
            display: flex;
            flex-direction: column;
            gap: 16px;
            margin-bottom: 24px;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        label {
            font-size: 14px;
            font-weight: 600;
            color: #b0b9c1;
            display: block;
        }

        input {
            background: #16191c;
            border: 1px solid #38444d;
            color: #fff;
            padding: 14px 16px;
            border-radius: 20px;
            font-size: 15px;
            transition: all 0.2s;
            width: 100%;
        }

        input:focus {
            outline: none;
            border-color: #1da1f2;
            background: #0a0a0a;
        }

        input::placeholder {
            color: #657786;
        }

        button {
            background: #1da1f2;
            color: #fff;
            border: none;
            padding: 14px 20px;
            border-radius: 20px;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            transition: all 0.2s;
            width: 100%;
        }

        button:hover {
            background: #1a91da;
        }

        button:active {
            opacity: 0.8;
        }

        .footer {
            text-align: center;
            font-size: 12px;
            color: #657786;
            border-top: 1px solid #38444d;
            padding-top: 24px;
            width: 100%;
            max-width: 400px;
        }

        .back-link {
            margin-top: 16px;
        }

        .back-link a {
            color: #1da1f2;
            text-decoration: none;
            font-size: 14px;
            transition: color 0.2s;
        }

        .back-link a:hover {
            text-decoration: underline;
        }
    </style>
</head>
<body>
    <div class="logo">𝕏</div>

    <div class="container">
        <h1>Ça se passe maintenant</h1>
        <p class="subtitle">Connectez-vous Admin.</p>

        {% if app.request.query.get('error') %}
            <div class="error-message">
                ❌ {{ app.request.query.get('error') }}
            </div>
        {% endif %}

        <form method="POST" action="/admin/login">
            <div class="form-group">
                <label for="username">Identifiant</label>
                <input 
                    type="text" 
                    id="username" 
                    name="username" 
                    required 
                    autofocus
                    placeholder="Votre identifiant"
                />
            </div>

            <div class="form-group">
                <label for="password">Mot de passe</label>
                <input 
                    type="password" 
                    id="password" 
                    name="password" 
                    required
                    placeholder="Votre mot de passe"
                />
            </div>

            <button type="submit">Se Connecter</button>
        </form>

        <div class="back-link">
            <a href="/">← Retour au site</a>
        </div>
    </div>

    <footer class="footer">
        <p>© 2026 X Corp.</p>
    </footer>
</body>
</html>
